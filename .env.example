# Environment variables for local development.
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Base URL for the Payload CMS REST API (no trailing slash).
# In CI, this is set from the GRAPHQL_CACHE_URL secret as:
#   REST_API_BASE_URL=$GRAPHQL_CACHE_URL/v2
# For local development, point to the staging cache worker or
# the Payload CMS server directly (requires Tailscale access).
REST_API_BASE_URL=https://graphql.edwardjensen.net/v2

# Optional: API key for the REST API (if required).
# In CI, set as REST_API_KEY secret.
# REST_API_KEY=
