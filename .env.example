# Environment variables for local development.
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Base URL of the Payload CMS REST API (no trailing slash, no /v2).
# The /v2 path is appended automatically by the API client.
# Requires Tailscale VPN to be connected.
#
# Production CMS: https://www-ts.edwardjensencms.com/api
# Staging CMS:    https://staging-tailscale.edwardjensencms.com/api
#
# NOTE: Previously this pointed at the Cloudflare KV content relay
# (https://contentrelay.edwardjensen.net). That relay is temporarily
# bypassed — see contexts/CONTENT_RELAY_BYPASS.md.
CONTENT_RELAY_URL=https://www-ts.edwardjensencms.com/api

# API key for the REST API — not needed for direct CMS access.
# The CMS v2 API allows unauthenticated reads; Tailscale provides access control.
# REST_API_KEY=
