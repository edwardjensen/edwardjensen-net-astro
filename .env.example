# Environment variables for local development.
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Base URL of the content relay worker (no trailing slash, no /v2).
# The /v2 path is appended automatically by the API client.
# In CI, set as the CONTENT_RELAY_URL secret.
# For local development, point to the relay or the Payload CMS server
# directly (requires Tailscale access — omit /v2 in either case).
CONTENT_RELAY_URL=https://contentrelay.edwardjensen.net

# Optional: API key for the REST API (if required).
# In CI, set as REST_API_KEY secret.
# REST_API_KEY=
