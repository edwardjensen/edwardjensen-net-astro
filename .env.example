# Environment variables for local development.
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Base URL of the Cloudflare KV content relay (no trailing slash, no /v2).
# The /v2 path is appended automatically by the API client.
# Production relay: https://contentrelay.edwardjensen.net
CONTENT_RELAY_URL=https://contentrelay.edwardjensen.net

# Read API key for the content relay (X-Read-Key header).
# Required for all relay reads. Set via wrangler secret on the relay worker.
CONTENT_RELAY_READ_KEY=
