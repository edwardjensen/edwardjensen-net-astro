---
/**
 * SectionCard — default article-container card wrapper used in landing pages.
 * Renders a header row with optional icon, section title, and optional subheader.
 */
interface Props {
  section: string;
  icon?: string;
  subheader?: string;
  id?: string;
}

const { section, icon, subheader } = Astro.props;
const headingId = section.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "") + "-heading";
---

<section class="article-container p-8 mb-8" aria-labelledby={headingId}>
  <header class="flex flex-col md:flex-row items-center md:items-center gap-4 mb-8 text-center md:text-left">
    {icon && (
      <div class="hidden md:flex w-12 h-12 bg-brand-orange rounded-xl items-center justify-center" aria-hidden="true">
        <i class={`ph ph-${icon} text-white text-xl`} aria-hidden="true"></i>
      </div>
    )}
    <div>
      <h2 id={headingId} class="font-header font-bold text-3xl text-heading tracking-wide lowercase transition-colors duration-300">
        {section}
      </h2>
      {subheader && (
        <p class="text-muted mt-1 lowercase transition-colors duration-300">{subheader}</p>
      )}
    </div>
  </header>
  <slot />
</section>
