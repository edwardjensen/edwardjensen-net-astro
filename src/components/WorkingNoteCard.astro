---
/**
 * WorkingNoteCard — single working note inline component (for the notes index).
 * Mirrors _includes/components/working-note.html
 */
interface Tag {
  tag?: string;
}

interface Props {
  id: number;
  index: number;
  title: string;
  date: string; // ISO
  tags: string[];
  contentHtml: string;
  url: string;
}

const { index, title, date, tags, contentHtml, url } = Astro.props;

const dateFormatted = new Date(date).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<article
  id={`note-${index}`}
  class="group list-item-hover p-4 border-l-4 border-brand-orange section-bg-white scroll-mt-24"
>
  <div class="space-y-3">
    <!-- Title + Tags -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
      <h3 class="text-heading font-semibold text-lg">{title}</h3>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1" role="list" aria-label="Note tags">
          {tags.map((tag) => (
            <span class="badge-accent" role="listitem">#{tag}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Content -->
    <div
      class="prose dark:prose-invert max-w-none [&_img]:rounded-lg [&_img]:my-2 [&_pre]:overflow-x-auto text-body"
      set:html={contentHtml}
    />

    <!-- Date + Permalink Footer -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 pt-2 border-t border-brand-grey/20 dark:border-brand-grey/30">
      <time class="text-xs font-mono text-muted" datetime={date}>
        {dateFormatted}
      </time>
      <a href={url} class="text-xs font-semibold link-accent">permalink</a>
    </div>
  </div>
</article>
