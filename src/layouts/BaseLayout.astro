---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import HeaderNav from "../islands/HeaderNav";
import Footer from "../components/Footer.astro";
import PhotoModal from "../components/PhotoModal.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  publishedAt?: string;
  updatedAt?: string;
}

const {
  title = "Edward Jensen",
  description,
  image,
  imageAlt,
  type,
  publishedAt,
  updatedAt,
} = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO meta tags, Open Graph, Twitter Cards, JSON-LD -->
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
    />

    <!-- Phosphor Icons via CDN -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Page-specific head content (injected by child layouts) -->
    <slot name="head" />
  </head>

  <body class="bg-brand-smoke dark:bg-brand-ink min-h-screen transition-colors duration-300">
    <!-- Skip to main content for screen readers -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-brand-orange text-white px-4 py-2 rounded-md z-50 focus:z-50"
    >
      Skip to main content
    </a>

    <!-- Sticky header navigation (Preact island — loads immediately) -->
    <HeaderNav client:load />

    <!-- Main page content -->
    <slot />

    <!-- Photo modal overlay — populated by public/assets/js/photo-gallery.js -->
    <PhotoModal />

    <!-- Footer -->
    <footer role="contentinfo" aria-label="Site footer">
      <Footer />
    </footer>
  </body>
</html>
